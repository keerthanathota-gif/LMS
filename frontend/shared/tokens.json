{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "LMS Design Tokens — Navy/Indigo theme. Import into Figma via Tokens Studio plugin.",

  "color": {
    "navy": {
      "50":  { "$value": "#f0f4f8", "$type": "color", "$description": "Light hover backgrounds" },
      "100": { "$value": "#d9e2ec", "$type": "color", "$description": "Borders, dividers" },
      "200": { "$value": "#bcccdc", "$type": "color", "$description": "Disabled states" },
      "300": { "$value": "#9fb3c8", "$type": "color", "$description": "Placeholder text" },
      "400": { "$value": "#627d98", "$type": "color", "$description": "Muted icons" },
      "500": { "$value": "#334e68", "$type": "color", "$description": "Secondary text" },
      "600": { "$value": "#2d3f50", "$type": "color", "$description": "Body text" },
      "700": { "$value": "#243b53", "$type": "color", "$description": "Admin sidebar bg" },
      "800": { "$value": "#1a2f44", "$type": "color", "$description": "Sidebar hover" },
      "900": { "$value": "#102a43", "$type": "color", "$description": "Sidebar deep" },
      "950": { "$value": "#0a1929", "$type": "color", "$description": "Sidebar darkest" }
    },
    "indigo": {
      "50":  { "$value": "#eef2ff", "$type": "color", "$description": "Light indigo tint" },
      "100": { "$value": "#e0e7ff", "$type": "color", "$description": "Selected bg" },
      "200": { "$value": "#c7d2fe", "$type": "color", "$description": "Focus ring light" },
      "300": { "$value": "#a5b4fc", "$type": "color", "$description": "Active badge bg" },
      "400": { "$value": "#818cf8", "$type": "color", "$description": "Active links, icons" },
      "500": { "$value": "#6366f1", "$type": "color", "$description": "Primary buttons, accents" },
      "600": { "$value": "#4f46e5", "$type": "color", "$description": "Button hover" },
      "700": { "$value": "#4338ca", "$type": "color", "$description": "Button pressed" },
      "800": { "$value": "#3730a3", "$type": "color", "$description": "Deep indigo" },
      "900": { "$value": "#312e81", "$type": "color", "$description": "Dark indigo" }
    },
    "surface": {
      "primary":   { "$value": "#ffffff", "$type": "color", "$description": "Main page background" },
      "secondary": { "$value": "#f8fafc", "$type": "color", "$description": "Card backgrounds, input bg" },
      "tertiary":  { "$value": "#f1f5f9", "$type": "color", "$description": "Hover states, alt rows" },
      "border":    { "$value": "#e2e8f0", "$type": "color", "$description": "Default border color" },
      "divider":   { "$value": "#cbd5e1", "$type": "color", "$description": "Heavier dividers" }
    },
    "text": {
      "primary":   { "$value": "#0f172a", "$type": "color", "$description": "Headings, body text" },
      "secondary": { "$value": "#475569", "$type": "color", "$description": "Descriptions, secondary info" },
      "muted":     { "$value": "#94a3b8", "$type": "color", "$description": "Placeholders, disabled" },
      "inverse":   { "$value": "#ffffff", "$type": "color", "$description": "Text on dark/indigo bg" }
    },
    "accent": {
      "amber":   { "$value": "#f59e0b", "$type": "color", "$description": "Stars, XP, warnings" },
      "emerald": { "$value": "#10b981", "$type": "color", "$description": "Success, completion, pass" },
      "rose":    { "$value": "#f43f5e", "$type": "color", "$description": "Errors, fail, destructive" },
      "sky":     { "$value": "#0ea5e9", "$type": "color", "$description": "Info, links, secondary CTA" },
      "violet":  { "$value": "#8b5cf6", "$type": "color", "$description": "Badges, special highlights" }
    }
  },

  "typography": {
    "fontFamily": {
      "body":    { "$value": "'Inter', system-ui, -apple-system, sans-serif", "$type": "fontFamily" },
      "display": { "$value": "'Plus Jakarta Sans', 'Inter', system-ui, sans-serif", "$type": "fontFamily" },
      "mono":    { "$value": "'JetBrains Mono', 'Fira Code', monospace", "$type": "fontFamily" }
    },
    "fontSize": {
      "xs":   { "$value": "0.6875rem", "$type": "dimension", "$description": "11px" },
      "sm":   { "$value": "0.8125rem", "$type": "dimension", "$description": "13px" },
      "base": { "$value": "0.875rem",  "$type": "dimension", "$description": "14px" },
      "lg":   { "$value": "1rem",      "$type": "dimension", "$description": "16px" },
      "xl":   { "$value": "1.125rem",  "$type": "dimension", "$description": "18px" },
      "2xl":  { "$value": "1.375rem",  "$type": "dimension", "$description": "22px" },
      "3xl":  { "$value": "1.75rem",   "$type": "dimension", "$description": "28px" },
      "4xl":  { "$value": "2.125rem",  "$type": "dimension", "$description": "34px" }
    },
    "fontWeight": {
      "normal":   { "$value": "400", "$type": "fontWeight" },
      "medium":   { "$value": "500", "$type": "fontWeight" },
      "semibold": { "$value": "600", "$type": "fontWeight" },
      "bold":     { "$value": "700", "$type": "fontWeight" }
    },
    "lineHeight": {
      "tight":  { "$value": "1.25", "$type": "number" },
      "normal": { "$value": "1.5",  "$type": "number" },
      "relaxed":{ "$value": "1.625","$type": "number" }
    }
  },

  "spacing": {
    "0":  { "$value": "0",      "$type": "dimension" },
    "1":  { "$value": "0.25rem","$type": "dimension", "$description": "4px" },
    "2":  { "$value": "0.5rem", "$type": "dimension", "$description": "8px" },
    "3":  { "$value": "0.75rem","$type": "dimension", "$description": "12px" },
    "4":  { "$value": "1rem",   "$type": "dimension", "$description": "16px" },
    "5":  { "$value": "1.25rem","$type": "dimension", "$description": "20px" },
    "6":  { "$value": "1.5rem", "$type": "dimension", "$description": "24px" },
    "8":  { "$value": "2rem",   "$type": "dimension", "$description": "32px" },
    "10": { "$value": "2.5rem", "$type": "dimension", "$description": "40px" },
    "12": { "$value": "3rem",   "$type": "dimension", "$description": "48px" },
    "16": { "$value": "4rem",   "$type": "dimension", "$description": "64px" }
  },

  "borderRadius": {
    "sm":   { "$value": "0.375rem", "$type": "dimension", "$description": "6px" },
    "md":   { "$value": "0.5rem",   "$type": "dimension", "$description": "8px" },
    "lg":   { "$value": "0.75rem",  "$type": "dimension", "$description": "12px" },
    "xl":   { "$value": "1rem",     "$type": "dimension", "$description": "16px" },
    "2xl":  { "$value": "1.25rem",  "$type": "dimension", "$description": "20px" },
    "full": { "$value": "9999px",   "$type": "dimension", "$description": "Pill shape" }
  },

  "shadow": {
    "sm":   { "$value": "0 1px 2px 0 rgba(15, 23, 42, 0.05)", "$type": "shadow" },
    "md":   { "$value": "0 4px 6px -1px rgba(15, 23, 42, 0.07), 0 2px 4px -2px rgba(15, 23, 42, 0.05)", "$type": "shadow" },
    "lg":   { "$value": "0 10px 15px -3px rgba(15, 23, 42, 0.08), 0 4px 6px -4px rgba(15, 23, 42, 0.04)", "$type": "shadow" },
    "xl":   { "$value": "0 20px 25px -5px rgba(15, 23, 42, 0.1), 0 8px 10px -6px rgba(15, 23, 42, 0.05)", "$type": "shadow" },
    "glow": { "$value": "0 0 20px rgba(99, 102, 241, 0.15)", "$type": "shadow", "$description": "Indigo glow for focus/active" }
  },

  "animation": {
    "duration": {
      "fast":   { "$value": "150ms", "$type": "duration" },
      "normal": { "$value": "200ms", "$type": "duration" },
      "slow":   { "$value": "300ms", "$type": "duration" },
      "gentle": { "$value": "500ms", "$type": "duration" }
    },
    "easing": {
      "default":  { "$value": "cubic-bezier(0.4, 0, 0.2, 1)", "$type": "cubicBezier" },
      "in":       { "$value": "cubic-bezier(0.4, 0, 1, 1)",   "$type": "cubicBezier" },
      "out":      { "$value": "cubic-bezier(0, 0, 0.2, 1)",   "$type": "cubicBezier" },
      "bounce":   { "$value": "cubic-bezier(0.34, 1.56, 0.64, 1)", "$type": "cubicBezier" }
    }
  }
}
