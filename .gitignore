# =============================================================================
# LMS — .gitignore
# =============================================================================

# Environment variables — NEVER commit these
.env
.env.local
.env.*.local
secrets/

# Node
node_modules/
dist/
build/
.next/
.turbo/
*.tsbuildinfo

# Python
__pycache__/
*.py[cod]
*.pyc
.venv/
venv/
env/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
dist/
*.dist-info/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/settings.json
.idea/
*.swp
*.swo

# Docker
.docker/

# Test coverage
coverage/
.nyc_output/
htmlcov/

# Certificates / Keys (generated locally)
*.pem
*.key
*.crt
*.p12

# Uploads / temp files
uploads/
tmp/
temp/

# Kubernetes secrets
k8s/secrets/

# Helm generated
charts/*.tgz
